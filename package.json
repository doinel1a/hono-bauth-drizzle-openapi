{
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Doinel Atanasiu",
    "email": "doinel+github@atanasiu.me",
    "url": "https://business-link.d1a.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/doinel1a/hono-drizzle-openapi"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx src/env.ts && tsx watch src/index.ts",
    "build": "tsup",
    "start": "tsx src/env.ts && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write **/**/*.{js,mjs,cjs,ts,mts,cts} --cache",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "ba:auth": "npx auth@latest generate",
    "db:studio": "drizzle-kit --config=drizzle/config.ts studio",
    "db:push": "drizzle-kit --config=drizzle/config.ts push",
    "db:create-migration": "drizzle-kit --config=drizzle/config.ts generate",
    "db:migrate": "drizzle-kit --config=drizzle/config.ts migrate"
  },
  "dependencies": {
    "@hono/node-server": "2.0.2",
    "@hono/zod-openapi": "1.4.0",
    "@loglayer/hono": "2.1.0",
    "@loglayer/transport-simple-pretty-terminal": "3.0.2",
    "@scalar/hono-api-reference": "0.10.16",
    "@t3-oss/env-core": "0.13.11",
    "better-auth": "1.6.11",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "hono": "4.12.18",
    "loglayer": "9.1.0",
    "pg": "8.20.0",
    "serialize-error": "13.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@electric-sql/pglite": "0.4.5",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "25.8.0",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.6",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  }
}
